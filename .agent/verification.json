{
  "required_files": [
    ".agent/contract.json",
    ".agent/evidence.json",
    ".agent/plan.json",
    ".agent/state.json",
    ".agent/review.json"
  ],
  "review_file": ".agent/review.json",
  "required_review_roles": [
    "spec-reviewer",
    "quality-reviewer"
  ],
  "commands": [
    {
      "name": "Tests",
      "command": ".venv/bin/python -m pytest -q",
      "timeout": 180
    },
    {
      "name": "Ruff",
      "command": ".venv/bin/ruff check .",
      "timeout": 120
    }
  ]
}
